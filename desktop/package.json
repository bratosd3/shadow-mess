{
  "name": "shadow-messenger-desktop",
  "version": "4.8.0",
  "description": "Shadow Messenger — Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build-installer": "electron-builder --win nsis"
  },
  "author": "Shadow Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.shadow.messenger",
    "productName": "Shadow Messenger",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["portable", "nsis"],
      "icon": "../static/icons/icon-512.svg"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "installerHeaderIcon": "../static/icons/icon-512.svg"
    }
  }
}
