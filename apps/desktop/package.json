{
  "name": "shadow-messenger-desktop",
  "version": "5.3.0",
  "description": "Shadow Messenger — Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-packager . \"Shadow Messenger\" --platform=win32 --arch=x64 --icon=../../static/icons/icon.ico --out=dist --overwrite --asar",
    "build-installer": "electron-builder --win nsis"
  },
  "author": "Shadow Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-packager": "^17.1.2",
    "electron-winstaller": "^5.4.0",
    "png-to-ico": "^3.0.1"
  },
  "build": {
    "appId": "com.shadow.messenger",
    "productName": "Shadow Messenger",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "../../static/icons/icon-512.png",
      "sign": null,
      "signingHashAlgorithms": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true,
      "installerHeaderIcon": "../../static/icons/icon.ico",
      "installerIcon": "../../static/icons/icon.ico",
      "uninstallerIcon": "../../static/icons/icon.ico",
      "installerSidebar": null,
      "shortcutName": "Shadow Messenger",
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "uninstallDisplayName": "Shadow Messenger v5.3",
      "deleteAppDataOnUninstall": true,
      "runAfterFinish": true,
      "include": "installer.nsh",
      "license": null,
      "installerLanguages": ["ru", "en_US"],
      "language": "1049",
      "artifactName": "Shadow-Messenger-Setup-${version}.${ext}",
      "warningsAsErrors": false
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../../static/icons/icon-512.png",
        "to": "icon.png"
      }
    ]
  }
}
